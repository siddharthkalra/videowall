<Window x:Class="VideoWallpaper.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VideoWallpaper"
        Height="620"
        Width="980"
        MinHeight="560"
        MinWidth="860"
        Background="#0C111B">
    <Window.Resources>
        <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0A1120" Offset="0" />
            <GradientStop Color="#13263F" Offset="0.45" />
            <GradientStop Color="#0B111A" Offset="1" />
        </LinearGradientBrush>

        <SolidColorBrush x:Key="GlassPanelBrush" Color="#2AFFFFFF" />
        <SolidColorBrush x:Key="GlassBorderBrush" Color="#66FFFFFF" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F4F8FF" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#C9D6EE" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#AFC1E0" />

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="22,12" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="MinWidth" Value="138" />
            <Setter Property="MinHeight" Value="48" />
            <Setter Property="Background" Value="#2CFFFFFF" />
            <Setter Property="BorderBrush" Value="#75FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#4DFFFFFF" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#CFFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#76FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,16,8" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Border Margin="18"
                CornerRadius="22"
                Background="{StaticResource GlassPanelBrush}"
                BorderBrush="{StaticResource GlassBorderBrush}"
                BorderThickness="1"
                Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30"
                                  ShadowDepth="0"
                                  Color="#6A000000"
                                  Opacity="0.65" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="VideoWallpaper"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   FontSize="30"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Minimal local video wallpaper controller"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="14" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Padding="14,10"
                            CornerRadius="14"
                            BorderThickness="1"
                            BorderBrush="#7FFFFFFF"
                            Background="#2DFFFFFF">
                        <StackPanel>
                            <TextBlock Text="Creator"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="12" />
                            <TextBlock Text="Dr. Siddharth Kalra"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,0,0,14"
                        Padding="14"
                        CornerRadius="16"
                        BorderThickness="1"
                        BorderBrush="#61FFFFFF"
                        Background="#26FFFFFF">
                    <WrapPanel VerticalAlignment="Center">
                        <Button Content="Pick Video"
                                Click="PickVideoButton_OnClick" />
                        <Button Content="Play Local"
                                Click="PlayLocalButton_OnClick" />
                        <Button Content="Stop"
                                Click="StopButton_OnClick" />
                        <Button Content="Hide UI"
                                Margin="0,0,16,10"
                                Click="HideUiButton_OnClick" />
                        <CheckBox x:Name="PauseOnFullscreenCheckBox"
                                  Content="Pause on Fullscreen"
                                  Checked="PauseOnFullscreenCheckBox_OnChanged"
                                  Unchecked="PauseOnFullscreenCheckBox_OnChanged" />
                        <CheckBox x:Name="PauseOnBatteryCheckBox"
                                  Content="Pause on Battery"
                                  Checked="PauseOnBatteryCheckBox_OnChanged"
                                  Unchecked="PauseOnBatteryCheckBox_OnChanged" />
                        <CheckBox x:Name="StartWithWindowsCheckBox"
                                  Content="Start with Windows"
                                  Checked="StartWithWindowsCheckBox_OnChecked"
                                  Unchecked="StartWithWindowsCheckBox_OnChecked" />
                    </WrapPanel>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,0,0,14"
                        Padding="18"
                        CornerRadius="16"
                        BorderThickness="1"
                        BorderBrush="#55FFFFFF"
                        Background="#1CFFFFFF">
                    <StackPanel>
                        <TextBlock Text="Mode Notes"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Text="• With Wallpaper Mode enabled, playback renders behind the desktop using the shell host.&#x0a;• With Wallpaper Mode disabled, playback runs in a normal video window.&#x0a;• Press Ctrl+Shift+Q to exit quickly." />
                    </StackPanel>
                </Border>

                <Border Grid.Row="3"
                        Padding="12"
                        CornerRadius="14"
                        BorderThickness="1"
                        BorderBrush="#66FFFFFF"
                        Background="#2DFFFFFF">
                    <TextBlock x:Name="StatusText"
                               Text="Ready"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
